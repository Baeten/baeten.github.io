<div class="card-text font-weight-light">
  {% for group in entries %}
    <h4 style="margin-top: 1.5rem; margin-bottom: 0.5rem; font-size: 1.1rem; font-weight: 500; color: var(--global-theme-color);">{{ group.subcategory }}</h4>
    <table class="table table-cv table-sm table-borderless table-responsive table-cv-map">
      {% for entry in group.items %}
        <tr>
          <td class="p-1 pr-2 font-weight-bold" style="min-width: 150px; vertical-align: top;">
            <b>{{ entry.label }}</b>
          </td>
          <td class="p-1 pl-2 font-weight-light text">
            {{ entry.details }}
          </td>
        </tr>
      {% endfor %}
    </table>
  {% endfor %}
</div>
