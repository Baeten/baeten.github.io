<div class="card-text font-weight-light">
  <table class="table table-cv table-sm table-borderless table-responsive table-cv-map">
    {% for group in entries %}
      <tr>
        <td colspan="2" style="padding-top: 1.5rem; padding-bottom: 0.5rem;">
          <h4 style="margin: 0; font-size: 1.1rem; font-weight: 500; color: var(--global-theme-color);">{{ group.subcategory }}</h4>
        </td>
      </tr>
      {% for entry in group.items %}
        <tr>
          <td class="p-1 pr-2 font-weight-bold" style="min-width: 250px; vertical-align: top;">
            {{ entry.label }}
          </td>
          <td class="p-1 pl-2 font-weight-light text" style="vertical-align: top;">
            {{ entry.details }}
          </td>
        </tr>
      {% endfor %}
    {% endfor %}
  </table>
</div>
